<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- izinkan semua file di cacheDir: /data/data/<package>/cache -->
    <cache-path
        name="scan_receipt_cache"
        path="." />

    <!-- kalau kamu juga pakai receipts di internal storage (filesDir/receipts),
         tambahkan ini supaya AddTransactionActivity bisa buka lagi -->
    <files-path
        name="receipts_dir"
        path="receipts/" />

</paths>
