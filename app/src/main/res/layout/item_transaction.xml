<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.WalletAI.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/md_theme_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false"
    app:strokeColor="@color/outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="84dp"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="@color/md_theme_primaryContainer"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivTransactionIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/ic_receipt_24"
                app:tint="@color/md_theme_primary" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTransactionTitle"
                style="@style/TextAppearance.WalletAI.TitleMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="McDonald's"
                android:textColor="@color/md_theme_onSurface" />

            <TextView
                android:id="@+id/tvTransactionSubtitle"
                style="@style/TextAppearance.WalletAI.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Food • BCA • 13 Mar 2026"
                android:textColor="@color/md_theme_onSurfaceVariant" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTransactionAmount"
            style="@style/TextAppearance.WalletAI.TitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="-Rp85.000"
            android:textAlignment="viewEnd"
            android:textStyle="bold" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>