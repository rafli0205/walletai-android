<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvScanTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scan Receipt"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <ImageView
        android:id="@+id/ivReceiptPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:contentDescription="Receipt preview" />

    <TextView
        android:id="@+id/tvOcrResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btnScanCamera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Scan dari kamera" />

        <Button
            android:id="@+id/btnPickImage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Ambil dari galeri" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCreateTransaction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buka transaksi dari struk"
        android:enabled="false"
        android:layout_marginTop="12dp" />

</LinearLayout>
